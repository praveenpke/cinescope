# Copy this file to .env and fill in your keys. Never commit .env.

# Anthropic API key — used by the FastAPI service to parse natural-language
# queries ("like Inception but funnier") into structured filters via Claude Haiku.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# TMDB API key (v3 auth, free tier) — used by the pipeline to hydrate plots,
# posters, and genres for MovieLens-linked titles.
# Get one at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Postgres connection for the pgvector serving database (docker-compose default)
DATABASE_URL=postgresql://cinescope:cinescope@localhost:5433/cinescope
